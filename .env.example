# Ollama local LLM (no cost — runs on your machine, Gemma 3 already installed)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# Subreddits to monitor (comma-separated)
TARGET_SUBREDDITS=fitness,loseit,nutrition,Entrepreneur,startups

# Email notifications (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_gmail_app_password
RECIPIENT_EMAIL=your_email@gmail.com

# Video output
VIDEO_OUTPUT_DIR=./videos/
TTS_ENGINE=pyttsx3
TTS_VOICE=male

# Approximate nutrition values (shown in video overlay — edit to match your recipes)
APPROXIMATE_CALORIES=420
APPROXIMATE_PROTEIN=28
APPROXIMATE_CARBS=35
APPROXIMATE_FAT=12

# App branding
NUTRIFITNESS_URL=nut-ri-fitness.app

# Scheduler intervals (seconds) — defaults: Reddit 2h, Video 12h
# REDDIT_SCAN_INTERVAL=7200
# VIDEO_FETCH_INTERVAL=43200


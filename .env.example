# Reddit credentials (required for posting)
REDDIT_USERNAME=your_reddit_username
REDDIT_PASSWORD=your_reddit_password

# Ollama local LLM (no cost, runs on your machine)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma

# Subreddits to monitor (comma-separated; leading/trailing spaces are stripped automatically)
TARGET_SUBREDDITS=fitness,loseit,nutrition,Entrepreneur,startups

# Flask dashboard port
FLASK_PORT=5000

# Seconds to wait between individual Reddit posts (random range)
POST_DELAY_MIN=30
POST_DELAY_MAX=120

# Max comments to post per day (safety cap)
POSTS_PER_DAY=3

# Your SaaS URL to mention naturally in comments
NUTRIFITNESS_URL=https://nutrifitness.com

# Scrape interval in seconds (default 2h min, 4h max)
# SCRAPE_INTERVAL_MIN=7200
# SCRAPE_INTERVAL_MAX=14400

# Posting check interval in seconds (default 30 min)
# POST_CHECK_INTERVAL=1800
